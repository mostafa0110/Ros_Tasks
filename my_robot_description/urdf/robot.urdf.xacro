<?xml version="1.0"?>
<robot name="my_diff_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include inertial calculations macros -->
  <xacro:include filename="inertial_macros.xacro"/>

  <!-- Auto-detected from ROS_DISTRO in the launch file:
       true  = Jazzy / Gazebo Sim (Ignition)
       false = Humble / Gazebo Classic -->
  <xacro:arg name="use_gz_sim" default="true"/>


  <!-- base_footprint: Projection of robot onto the ground plane -->
  <link name="base_footprint"/>

  <!-- base_link: The main coordinate frame of the robot chassis -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
      <material name="orange"><color rgba="1.0 0.55 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="5.0" x="0.4" y="0.3" z="0.15">
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Elevate base_link relative to base_footprint (wheels center height) -->
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- Drive Wheels Setup -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_thickness" value="0.04"/>

  <xacro:macro name="wheel" params="prefix y_offset">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
      </collision>
      <xacro:inertial_cylinder mass="0.5" radius="${wheel_radius}" length="${wheel_thickness}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_cylinder>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <!-- Wheel offset on Y axis, oriented horizontally (rotate around X axis) -->
      <origin xyz="-0.05 ${y_offset} 0" rpy="-1.5708 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left" y_offset="0.17"/>
  <xacro:wheel prefix="right" y_offset="-0.17"/>

  <!-- Castor Wheel (Passive balance wheel) -->
  <link name="castor_wheel">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.1" radius="0.05">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
  </link>

  <joint name="castor_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="castor_wheel"/>
    <!-- Positioned forward, lowered to touch the ground (0.1m wheels radius - 0.05m castor radius) -->
    <origin xyz="0.15 0 -0.05" rpy="0 0 0"/>
  </joint>



  <!-- ============================================ -->
  <!--         Gazebo Simulation                    -->
  <!-- ============================================ -->

  <!-- Wheel friction — keeps wheels gripping the ground -->
  <gazebo reference="left_wheel">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <gazebo reference="castor_wheel">
    <!-- Near-zero friction so the castor slides freely -->
    <mu1 value="0.001"/>
    <mu2 value="0.001"/>
  </gazebo>

  <!-- ===== Gazebo Diff Drive Plugin ===== -->
  <!-- Reads /cmd_vel and drives the wheels. Publishes /odom and /tf. -->
  <gazebo>
    <xacro:if value="$(arg use_gz_sim)">
      <!-- Jazzy / Gazebo Sim (Ignition) -->
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.34</wheel_separation>
        <wheel_radius>0.1</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
      </plugin>

      <!-- Publish wheel joint angles to /joint_states (needed by robot_state_publisher) -->
      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        <topic>joint_states</topic>
        <joint_name>left_wheel_joint</joint_name>
        <joint_name>right_wheel_joint</joint_name>
      </plugin>
    </xacro:if>

    <xacro:unless value="$(arg use_gz_sim)">
      <!-- Humble / Gazebo Classic -->
      <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.34</wheel_separation>
        <wheel_diameter>0.2</wheel_diameter>
        <max_wheel_torque>20.0</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>
      </plugin>
    </xacro:unless>
  </gazebo>

</robot>
